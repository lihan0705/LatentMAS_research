def prime_factors(n):
    factors = []
    # Handle 2 separately
    while n % 2 == 0:
        factors.append(2)
        n = n // 2
    # Check for odd factors starting from 3
    i = 3
    while i * i <= n:
        while n % i == 0:
            factors.append(i)
            n = n // i
        i += 2
    # If n is a prime number greater than 2
    if n > 1:
        factors.append(n)
    return factors

